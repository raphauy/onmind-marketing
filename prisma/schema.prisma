generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  image          String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  otpTokens          OtpToken[]
  deletedPieces      Piece[]
  leadActivities     LeadActivity[]
  ownedLeads         Lead[]              @relation("LeadOwner")
  messageTemplates   MessageTemplate[]
  availabilityRules  AvailabilityRule[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
}

model OtpToken {
  id        String    @id @default(cuid())
  token     String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// InstagramPublish — DEPRECATED, migrado a Publication
// Mantener temporalmente por si hace falta rollback
model InstagramPublish {
  id          String   @id @default(cuid())
  slug        String   @unique
  igMediaId   String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ── Motor de Contenido ─────────────────────────────────────────

// Template: receta fija para generar una imagen.
// Define el prompt con placeholders, el modelo de IA, y qué campos necesita el creativo.
model Template {
  id          String  @id @default(cuid())
  slug        String  @unique // "headline", "features-pointout", "us-vs-them"
  name        String // "Headline + celular con WhatsApp"
  description String? // Descripción para el creativo

  // Definición de campos que el creativo debe llenar.
  // Array de objetos: [{key, label, type, required, placeholder}]
  // type: "text" | "textarea" | "list" | "stat-list" | "conversation"
  // Ejemplo: [{key: "headline", label: "Título principal", type: "text", required: true}]
  fields Json

  // Motor de render: LLM (imagen generativa vía OpenRouter) o SATORI (render programático JSX -> PNG).
  renderer TemplateRenderer @default(LLM)

  // Prompt template con placeholders {{key}} que se reemplazan con los valores del creativo.
  // Incluye Brand DNA, dirección fotográfica, reglas — todo fijo.
  // Requerido para renderer=LLM, null para renderer=SATORI.
  promptTemplate String?

  // Modelo de IA a usar para este template.
  // Requerido para renderer=LLM, null para renderer=SATORI.
  model String?

  // Costo estimado en USD por imagen generada con este template/modelo
  costPerImage Float @default(0)

  // Duración en segundos para templates de video (renderer=REMOTION).
  // Null para templates de imagen estática (LLM, SATORI).
  durationSec Int?

  // Configuración visual
  darkOverlay Boolean @default(false) // Si el logo debe ir en blanco (fondo oscuro)
  aspectRatio String  @default("4:5") // "4:5", "1:1", "9:16"

  // Si el template soporta regenerar piezas existentes desde la UI.
  // false para templates bespoke (HYPERFRAMES) donde cada pieza es única.
  isRegeneratable Boolean @default(true)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pieces Piece[]
}

// Piece: una pieza creativa — los datos que el creativo define + la imagen generada.
model Piece {
  id   String @id @default(cuid())
  slug String @unique

  templateId String
  template   Template @relation(fields: [templateId], references: [id])

  // Clasificación
  pillar String? // "educacion", "dolor", "producto", "detras_de_escena"
  topic  String? // Tema libre: "Cumpleaños olvidados"

  // Datos creativos — los valores que llena el creativo según template.fields
  // Objeto con los keys definidos en el template: {headline: "...", subhead: "...", ...}
  fieldValues Json

  // Caption para Instagram (texto del post, se escribe aparte de la imagen)
  caption  String?
  hashtags String[] @default([])

  // Estado
  status PieceStatus @default(DRAFT)

  // Asset activo (apunta a la generación seleccionada)
  imageUrl     String? // URL de imagen (templates LLM, SATORI) o thumbnail (REMOTION)
  videoUrl     String? // URL de video MP4 (templates REMOTION). Null para imagen estática.
  thumbnailUrl String? // URL del frame de preview para video (REMOTION). Null si no aplica.
  costUsd      Float   @default(0) // Costo total acumulado de todas las generaciones

  // Soft delete
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation(fields: [deletedById], references: [id])

  // Historial de generaciones
  generations Generation[]

  // Publicación
  publications Publication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([pillar])
  @@index([templateId])
}

// Generation: registro de cada intento de generación de imagen.
// Nunca se borran — son el historial completo de inversión y versiones.
model Generation {
  id      String @id @default(cuid())
  pieceId String
  piece   Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  // Para templates de imagen (LLM, SATORI) imageUrl tiene la imagen final.
  // Para templates de video (REMOTION) imageUrl tiene el thumbnail y videoUrl tiene el MP4.
  imageUrl String // URL de Vercel Blob (siempre presente — imagen o thumbnail)
  videoUrl String? // URL de Vercel Blob del MP4 (solo REMOTION)

  prompt     String // Prompt enviado al modelo (LLM) o snapshot de inputs (SATORI/REMOTION)
  model      String // Modelo usado (ej: google/gemini-3.1-flash-image-preview, satori:slug, remotion:slug)
  costUsd    Float // Costo de esta generación
  durationMs Int // Duración en ms

  isActive Boolean @default(true) // Si es la generación activa (la que se muestra)

  createdAt DateTime @default(now())

  @@index([pieceId])
}

model Publication {
  id      String @id @default(cuid())
  pieceId String
  piece   Piece  @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  platform    String // "instagram", "linkedin"
  platformId  String? // igMediaId, etc.
  scheduledAt DateTime?
  publishedAt DateTime?

  status    PublicationStatus @default(PENDING)
  attempts  Int               @default(0)
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([pieceId])
}

enum PieceStatus {
  DRAFT // Creativo llenó los datos, sin imagen aún
  GENERATING // Generando imagen
  GENERATED // Imagen lista, pendiente de revisión
  APPROVED // Revisada y aprobada
  SCHEDULED // Tiene publicación programada
  PUBLISHED // Publicada
  FAILED // Generación falló
}

enum PublicationStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum TemplateRenderer {
  LLM // Imagen generada por modelo de IA vía OpenRouter (prompt + modelo)
  SATORI // Render programático JSX -> SVG -> PNG (sin LLM, determinista, cero costo)
  REMOTION // Video MP4 programático React -> Chromium headless -> H.264 (cero costo)
  HYPERFRAMES // Video MP4 narrado bespoke (HyperFrames + ElevenLabs voz/música). No paramétrico.
}

// ── CRM de Leads ───────────────────────────────────────────────

// Lead: prospecto que llegó por la landing, Instagram, referidos, etc.
// Se centraliza el seguimiento del pipeline desde "Nuevo" hasta "Cliente / Perdido".
model Lead {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String?
  status       LeadStatus @default(NEW)
  source       LeadSource @default(WEB)
  businessType String? // Rubro / tipo de negocio (libre)

  // Owner asignado (Raphael o Martín). Round-robin par/impar al crear, override manual.
  ownerUserId String?
  owner       User?   @relation("LeadOwner", fields: [ownerUserId], references: [id])

  // Booking de la demo (link de agendar + slot reservado).
  // Relación 1:1 — un lead tiene a lo sumo un booking activo.
  booking Booking?

  // Fecha de inicio del trial pago de 15 días.
  // Se setea automáticamente la primera vez que el lead entra en estado IN_EVALUATION.
  // Si vuelve a un estado anterior y avanza de nuevo, NO se resetea.
  trialStartedAt DateTime?

  activities LeadActivity[]
  followUps  LeadFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@index([ownerUserId])
}

// LeadActivity: timeline de eventos del lead.
// Mezcla notas del usuario + cambios de estado automáticos + eventos del sistema.
model LeadActivity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type    LeadActivityType
  message String

  authorUserId String?
  authorUser   User?   @relation(fields: [authorUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

enum LeadStatus {
  NEW // Llegó, sin contacto aún
  CONTACTED // Le mandamos el primer mensaje
  DEMO_SCHEDULED // Reservó slot de demo
  DEMO_DONE // La demo ya ocurrió
  IN_EVALUATION // En los 15 días de trial pago
  CUSTOMER // Suscripción activa
  LOST // Se perdió en algún punto del pipeline
}

enum LeadSource {
  INSTAGRAM
  WEB
  REFERRAL
  OTHER
}

enum LeadActivityType {
  NOTE // Nota libre escrita por un usuario
  STATUS_CHANGE // Cambio de estado (auto, registra el delta)
  SYSTEM // Evento del sistema (webhook, copia de mensaje, etc.)
}

// Plantillas de mensaje configurables por usuario.
// Cada usuario tiene su propio set: email + WhatsApp para cada propósito (booking link y follow-ups).
// Variables disponibles: {nombre} en todos, {linkBooking} solo en BOOKING_LINK.
model MessageTemplate {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   MessageTemplateChannel
  purpose   MessageTemplatePurpose
  // Solo aplica a channel = EMAIL. Para WhatsApp queda null.
  subject   String?
  body      String
  updatedAt DateTime               @updatedAt
  createdAt DateTime               @default(now())

  @@unique([userId, channel, purpose])
  @@index([userId])
}

enum MessageTemplateChannel {
  EMAIL
  WHATSAPP
}

enum MessageTemplatePurpose {
  BOOKING_LINK // "Te paso el link para agendar la demo"
  FOLLOWUP_CONTACTED // Lead en CONTACTED sin respuesta
  FOLLOWUP_DEMO_DONE // Lead en DEMO_DONE sin avanzar
  CHECKIN_CUSTOMER_MONTH_1 // Cliente, check-in a mitad del primer mes
}

// Disponibilidad recurrente por usuario.
// Define un bloque semanal (ej. "lunes 10:00-12:00") en hora local UY (America/Montevideo).
// Los slots concretos se proyectan al pedir disponibilidad para un rango de fechas.
model AvailabilityRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Domingo, 1=Lunes, ..., 6=Sábado (JS Date.getDay)
  startTime String // "HH:mm" en hora UY
  endTime   String // "HH:mm" en hora UY (exclusive)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, active])
}

// Bloqueo puntual: invalida un slot que cae dentro de [startsAt, endsAt) en UTC.
// Permite una reunión inesperada que choca con la plantilla.
model AvailabilityBlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt  DateTime // UTC
  endsAt    DateTime // UTC
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId, startsAt])
}

// Booking: link único por lead para que elija slot.
// Estado PENDING al generarse, CONFIRMED al reservar, CANCELLED si se cancela.
model Booking {
  id            String        @id @default(cuid())
  leadId        String        @unique
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerUserId   String
  owner         User          @relation(fields: [ownerUserId], references: [id])
  token         String        @unique
  status        BookingStatus @default(PENDING)
  // Slot reservado (UTC). Null mientras está PENDING.
  startsAt      DateTime?
  endsAt        DateTime?
  reservedAt    DateTime?
  // Marcador opcional para el botón "Crear evento en Google Calendar" desde el detail.
  calendarEventCreated Boolean @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([ownerUserId, startsAt])
}

enum BookingStatus {
  PENDING // Link generado, lead aún no reservó
  CONFIRMED // Lead eligió slot
  CANCELLED // Cancelado manualmente
}

// Follow-up automatizado: marca de "este lead se quedó frío en X estado".
// El cron diario crea uno cuando un lead cumple el umbral de inactividad y no
// tiene follow-up activo (resolvedAt IS NULL) para ese triggerState.
// Resoluciones:
// - STATE_CHANGE: el lead cambió de estado, se resuelve automáticamente.
// - USER_ACTION: el owner marcó "follow-up hecho" desde el panel/detail.
// - DISMISSED: descartado manualmente sin haber hecho contacto.
model LeadFollowUp {
  id           String              @id @default(cuid())
  leadId       String
  lead         Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  triggerState LeadStatus
  dueAt        DateTime
  notifiedAt   DateTime?
  resolvedAt   DateTime?
  resolvedBy   FollowUpResolvedBy?
  createdAt    DateTime            @default(now())

  @@index([leadId])
  @@index([resolvedAt])
}

enum FollowUpResolvedBy {
  STATE_CHANGE
  USER_ACTION
  DISMISSED
}
